# Neon PostgreSQL database connection string (required)
DATABASE_URL="postgres://user:password@hostname.neon.tech/dbname?sslmode=require"

# Public URL of the deployed app (optional, defaults to http://localhost:3000)
# Used by Server Components for internal fetch calls
# Example: NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
